pub fn hello_world_test() {
  synapses.hello_world()
  |> should.equal("Hello, from synapses!")
}

pub fn network_from_json_test() {
  let my_neuron =
    net_json()
    |> network.from_json
    |> zlist.head
    |> result.unwrap(zlist.new())
    |> zlist.head
    |> result.unwrap(neuron.init(0, activation.tanh(), fn() { 0.5 }))
  my_neuron.activation_f.name
  |> should.equal("sigmoid")
}

